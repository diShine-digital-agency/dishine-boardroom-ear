# diShine Boardroom Ear — Environment variables
# Copy this file to .env and fill in the values.
# The .env file is gitignored and must NEVER be committed.

# -----------------------------------------------------------------------
# Anthropic API key for Strategic Action Plan generation (optional).
# If left blank, the strategic planning step is skipped.
# Obtain your key at: https://console.anthropic.com/
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------
# Override config.yaml settings via environment (all optional).
# -----------------------------------------------------------------------
# BOARDROOM_MODEL_SIZE=small        # tiny | base | small | medium | large | large-v3
# BOARDROOM_DEVICE=auto             # cpu | cuda | mps | auto
# BOARDROOM_COMPUTE_TYPE=float32    # int8 | float16 | float32 | int8_float16
# BOARDROOM_OUTPUT_DIR=transcripts
# BOARDROOM_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
# BOARDROOM_LOG_FILE=               # leave blank to log to stdout only
# BOARDROOM_AUDIT_LOG=transcripts/audit.log
